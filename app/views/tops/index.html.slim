.meetia-modern-lp
  / ナビゲーションバー
  header.meetia-nav
    .meetia-nav__inner
      .meetia-nav__logo
        span.meetia-nav__logo-text Meetia.
        span.meetia-nav__logo-kana ミーティア
      nav.meetia-nav__menu
        a.meetia-nav__item href="#overview" Meetiaとは
        a.meetia-nav__item href="#problems" お悩み
        a.meetia-nav__item href="#features" 機能
        a.meetia-nav__item href="#flow" フロー
        a.meetia-nav__item href="#pricing" 料金
        a.meetia-nav__item href="#cases" お客様の声
        a.meetia-nav__item href="#faq" FAQ
      .meetia-nav__actions
        - if client_signed_in?
          = link_to "マイページ", dashboard_root_path, class: "meetia-btn meetia-btn--ghost"
        - elsif admin_signed_in?
          = link_to "管理画面", admin_root_path, class: "meetia-btn meetia-btn--ghost"
        - elsif user_signed_in?
          = link_to "マイページ", interview_path, class: "meetia-btn meetia-btn--ghost"
        - else
          = link_to "ログイン", new_client_session_path, class: "meetia-btn meetia-btn--ghost"
          = link_to "無料で試す", new_client_registration_path, class: "meetia-btn meetia-btn--glass"

  / 1. トップLP（ヒーローセクション）
  section.meetia-hero
    .meetia-hero__inner
      .meetia-hero__content
        .meetia-hero__badge
          span.meetia-hero__badge-dot
          | Next-Gen AI Sales Agent
        h1.meetia-hero__title
          | その営業商談、
          br
          | いつまで続けますか？
          br
          span.meetia-text-gradient AIが商談をスマートに
        ul.meetia-hero__bullets
          li 営業商談工数を０へ
          li ユーザーが知りたい時に知りたい情報を
          li AI営業で変わる圧倒的な分析力
        .meetia-hero__actions
          = link_to "無料トライアルを開始", "/clients/sign_up", class: "meetia-btn meetia-btn--primary meetia-btn--lg"
          a.meetia-btn.meetia-btn--secondary.meetia-btn--lg href="#overview" AI商談を体験

