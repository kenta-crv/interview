- set_meta_tags title: t("meetia.lp.meta_title")
- set_meta_tags description: t("meetia.lp.meta_description")

.meetia-modern-lp
  header.meetia-nav
    .meetia-nav__inner
      = link_to locale_root_href, class: "meetia-nav__logo" do
        = image_tag "meetia_logo.png", alt: "Meetia", class: "meetia-nav__logo-image"
      button.meetia-nav__toggle type="button" aria-label=t("meetia.lp.body.aria_menu") data-lp-nav-toggle=""
        span
        span
        span
      nav.meetia-nav__menu data-lp-nav-menu=""
        - lp_nav_items.each do |item|
          = link_to item[:label], item[:href], class: "meetia-nav__item"
        .meetia-nav__menu-actions
          = render "shared/lang_switch"
          = link_to lp_login_label, lp_login_path, class: "meetia-btn meetia-btn--ghost meetia-btn--sm"
          = link_to t("meetia.lp.cta_trial"), lp_sign_up_path, class: "meetia-btn meetia-btn--primary meetia-btn--sm"

  section#top.meetia-hero.meetia-hero--diagonal
    .meetia-hero__diagonal-bg aria-hidden="true"
    .meetia-hero__inner
      .meetia-hero__content
        .meetia-hero__badge
          i.fa-solid.fa-user-tie aria-hidden="true"
          span AI Sales Agent
        h1.meetia-hero__title
          = t("meetia.lp.hero_title_1")
          br
          = t("meetia.lp.hero_title_2")
        p.meetia-hero__lead = t("meetia.lp.hero_lead")
        .meetia-hero__actions
          = link_to lp_trial_experience_path, lp_trial_experience_link_options.merge(class: "meetia-btn meetia-btn--primary meetia-btn--lg meetia-btn--cta-play") do
            span = t("meetia.lp.cta_experience")
            span.meetia-btn__play-icon aria-hidden="true"
              i.fa-solid.fa-play
          = link_to t("meetia.lp.cta_features"), "#features", class: "meetia-btn meetia-btn--outline meetia-btn--lg"

      .meetia-hero__visual aria-hidden="true"
        .meetia-hero-portal
          = image_tag "top_hero.png", class: "meetia-hero-portal__scene", alt: t("meetia.lp.hero_image_alt")

    .meetia-hero__features
      - hero_feature_cards.each do |icon, title, body|
        .meetia-hero__feature-card
          .meetia-hero__feature-icon
            i.fa-solid class=icon aria-hidden="true"
          h3.meetia-hero__feature-title = title
          p.meetia-hero__feature-body = body

  /.meetia-logos
    p.meetia-logos__title = t("meetia.lp.logos_title")
    .meetia-logos__wrapper
      - %w[TechCorp NextVision CloudScale DataBridge InnovateX GlobalNet FutureWorks SmartBiz].each do |name|
        span.meetia-logos__item = name

        

  section.meetia-whats
    .meetia-whats__inner
      span.meetia-section__eyebrow What's Meetia?

      /-- 背景枠カード --/
      .meetia-whats__container-card
        
        /-- 完全に右側背景としてなじませるアバター（左側のテキスト領域に干渉させない） --/
        .meetia-whats__backdrop-visual
          .meetia-whats__glow-effect
          = image_tag "whats.png", class: "meetia-whats__avatar-backdrop", alt: ""

        /-- 枠内コンテンツ（z-indexでアバターより必ず前面に表示） --/
        .meetia-whats__card-body
          
          /-- 上半分のテキスト ＋ 実績エリア --/
          .meetia-whats__hero-block
            .meetia-whats__text-group
              h2.meetia-whats__main-title
                = image_tag "meetia_logo.png", class: "meetia-whats__logo-graphics", alt: "Meetia"
                span = t("meetia.lp.body.whats_suffix")
              p.meetia-whats__catch = t("meetia.lp.whats_catch")
              p.meetia-whats__description
                = t("meetia.lp.whats_desc_1")
                span.meetia-whats__description-more
                  br
                  = t("meetia.lp.whats_desc_2")
                  br
                  = t("meetia.lp.whats_desc_3")

            /-- 実績数値メーター --/
            .meetia-whats__metrics-row
              .meetia-whats__metric-item
                .meetia-whats__metric-icon-wrap
                  i.fa-solid.fa-clock-rotate-left
                  span 24h
                .meetia-whats__metric-texts
                  span.meetia-whats__metric-label = t("meetia.lp.body.metric_24_label")
                  span.meetia-whats__metric-value = t("meetia.lp.body.metric_24_value")
              .meetia-whats__metric-item
                .meetia-whats__metric-icon-wrap
                  i.fa-solid.fa-users
                .meetia-whats__metric-texts
                  span.meetia-whats__metric-label = t("meetia.lp.body.metric_leads_label")
                  span.meetia-whats__metric-value = t("meetia.lp.body.metric_leads_value")
              .meetia-whats__metric-item
                .meetia-whats__metric-icon-wrap
                  i.fa-solid.fa-chart-line
                .meetia-whats__metric-texts
                  span.meetia-whats__metric-label = t("meetia.lp.body.metric_appt_label")
                  span.meetia-whats__metric-value = t("meetia.lp.body.metric_appt_value")

          /-- 魅力カードグリッド（等幅・等高で枠の中に綺麗に収める） --/
          .meetia-whats__features-grid
            .meetia-whats__feature-box
              .meetia-whats__feature-icon-circle
                i.fa-solid.fa-comments
              h4.meetia-whats__feature-box-title = t("meetia.lp.body.box_talk_title")
              p.meetia-whats__feature-box-desc = t("meetia.lp.body.box_talk_desc")

            .meetia-whats__feature-box
              .meetia-whats__feature-icon-circle
                i.fa-solid.fa-clock
              h4.meetia-whats__feature-box-title = t("meetia.lp.body.box_24_title")
              p.meetia-whats__feature-box-desc = t("meetia.lp.body.box_24_desc")

            .meetia-whats__feature-box
              .meetia-whats__feature-icon-circle
                i.fa-solid.fa-bullseye
              h4.meetia-whats__feature-box-title = t("meetia.lp.body.box_approach_title")
              p.meetia-whats__feature-box-desc = t("meetia.lp.body.box_approach_desc")

            .meetia-whats__feature-box
              .meetia-whats__feature-icon-circle
                i.fa-solid.fa-chart-column
              h4.meetia-whats__feature-box-title = t("meetia.lp.body.box_viz_title")
              p.meetia-whats__feature-box-desc = t("meetia.lp.body.box_viz_desc")



  section#problems.meetia-section.meetia-problems
    .meetia-section__inner
      .meetia-section__head
        span.meetia-section__eyebrow = t("meetia.lp.problems_eyebrow")
        h2.meetia-section__title
          = t("meetia.lp.problems_title_1")
          span.meetia-text-gradient = t("meetia.lp.problems_title_2")
          = t("meetia.lp.problems_title_3")
      .meetia-problems__scroll-wrap
        button.meetia-problems__scroll-btn.meetia-problems__scroll-btn--prev type="button" aria-label=t("meetia.lp.body.aria_prev") data-lp-scroll-prev=".meetia-problems__grid"
          i.fa-solid.fa-chevron-left aria-hidden="true"
        .meetia-problems__grid
          - problem_items.each do |item|
            .meetia-problems__card
              .meetia-problems__icon
                i.fa-solid class=item[:icon] aria-hidden="true"
              .meetia-problems__content
                .meetia-problems__check-line
                  span.meetia-problems__check aria-hidden="true"
                  p.meetia-problems__title == item[:text]
                p.meetia-problems__desc = item[:desc]
        button.meetia-problems__scroll-btn.meetia-problems__scroll-btn--next type="button" aria-label=t("meetia.lp.body.aria_next") data-lp-scroll-next=".meetia-problems__grid"
          i.fa-solid.fa-chevron-right aria-hidden="true"
      .meetia-problems__arrow aria-hidden="true"
        i.fa-solid.fa-caret-down
      .meetia-problems__solution
        .meetia-problems__solution-copy
          .meetia-problems__solution-lead
            span = t("meetia.lp.body.problems_solution_1")
            span.meetia-text-gradient = t("meetia.lp.body.problems_solution_2")
          .meetia-problems__solution-brand
            span.meetia-problems__solution-mark aria-hidden="true"
              i.fa-solid.fa-headset
            strong.meetia-problems__solution-name Meetia
            span.meetia-problems__solution-suffix = t("meetia.lp.body.problems_solution_3")
            span.meetia-text-gradient = t("meetia.lp.body.problems_solution_4")
            span.meetia-problems__solution-suffix = t("meetia.lp.body.problems_solution_5")
        .meetia-problems__solution-visual aria-hidden="true"
          .meetia-problems__solution-mock
            .meetia-problems__solution-mock-head
              span
              span
              span
            .meetia-problems__solution-mock-row
              i.fa-solid.fa-file-lines
              span = t("meetia.lp.body.flow_badge_docs")
            .meetia-problems__solution-mock-row
              i.fa-solid.fa-microphone-lines
              span = t("meetia.lp.body.flow_badge_voice")
            .meetia-problems__solution-mock-row
              i.fa-solid.fa-chart-line
              span = t("meetia.lp.body.flow_badge_analytics")
          .meetia-problems__solution-deco.meetia-problems__solution-deco--sparkle
            i.fa-solid.fa-sparkles
          .meetia-problems__solution-deco.meetia-problems__solution-deco--chat
            i.fa-solid.fa-comments
          .meetia-problems__solution-deco.meetia-problems__solution-deco--chart
            i.fa-solid.fa-chart-column






  section#whats.meetia-section.meetia-section--strip
    .meetia-section__inner.meetia-section__inner--wide
      section.meetia-ai-deal-flow
        .meetia-ai-deal-flow__inner
          .meetia-ai-deal-flow__head
            span.meetia-section__eyebrow AI DEAL FLOW
            h2.meetia-ai-deal-flow__title = t("meetia.lp.body.flow_title")
            p.meetia-ai-deal-flow__subtitle
              span = t("meetia.lp.body.flow_badge_docs")
              span.meetia-ai-deal-flow__subtitle-x ×
              span = t("meetia.lp.body.flow_badge_voice")
              span.meetia-ai-deal-flow__subtitle-x ×
              span = t("meetia.lp.body.flow_badge_analytics")


          .meetia-ai-deal-flow__scroll-wrap
            button.meetia-ai-deal-flow__scroll-btn.meetia-ai-deal-flow__scroll-btn--prev type="button" aria-label=t("meetia.lp.body.aria_prev") data-lp-scroll-prev=".meetia-ai-deal-flow__steps"
              i.fa-solid.fa-chevron-left aria-hidden="true"
            .meetia-ai-deal-flow__steps
              .meetia-ai-deal-flow__step
                .meetia-ai-deal-flow__step-label
                  span.meetia-ai-deal-flow__step-num 1
                  p = t("meetia.lp.body.flow_web_click")
                .meetia-ai-deal-flow__panel.meetia-ai-deal-flow__panel--entry
                  .meetia-ai-deal-flow__phone
                    .meetia-ai-deal-flow__phone-notch aria-hidden="true"
                    .meetia-ai-deal-flow__phone-screen
                      .meetia-ai-deal-flow__phone-logo
                        span.meetia-ai-deal-flow__phone-logo-mark aria-hidden="true"
                        | Meetia
                      h3.meetia-ai-deal-flow__phone-title
                        = t("meetia.lp.body.flow_phone_1")
                        br
                        = t("meetia.lp.body.flow_phone_2")
                      p.meetia-ai-deal-flow__phone-lead = t("meetia.lp.body.flow_phone_lead")
                      .meetia-ai-deal-flow__phone-cta
                        = t("meetia.lp.body.flow_start_deal")
                        i.fa-solid.fa-arrow-pointer.meetia-ai-deal-flow__phone-cursor aria-hidden="true"
                      ul.meetia-ai-deal-flow__phone-list
                        li
                          i.fa-solid.fa-file-lines aria-hidden="true"
                          = t("meetia.lp.body.flow_point_1")
                        li
                          i.fa-solid.fa-microphone-lines aria-hidden="true"
                          = t("meetia.lp.body.flow_point_2")
                        li
                          i.fa-solid.fa-chart-line aria-hidden="true"
                          = t("meetia.lp.body.flow_point_3")

              span.meetia-ai-deal-flow__arrow aria-hidden="true"
                i.fa-solid.fa-chevron-right

              .meetia-ai-deal-flow__step.meetia-ai-deal-flow__step--room
