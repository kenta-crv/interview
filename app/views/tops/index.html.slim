            = t("meetia.lp.body.flow_footer_2")


  section#service.meetia-section.meetia-service-concept
    .meetia-section__inner
      .meetia-section__head.meetia-service-head
        span.meetia-section__eyebrow SERVICE
        h2.meetia-section__title
          = t("meetia.lp.service_title_1")
          span.meetia-text-gradient = t("meetia.lp.service_title_2")
        p.meetia-section__lead = t("meetia.lp.service_lead")
      .meetia-service-concept__scroll-wrap
        button.meetia-service-concept__scroll-btn.meetia-service-concept__scroll-btn--prev type="button" aria-label=t("meetia.lp.body.aria_prev") data-lp-scroll-prev=".meetia-service-concept__grid"
          i.fa-solid.fa-chevron-left aria-hidden="true"
        .meetia-service-concept__grid
          - service_cards.each do |card|
            .meetia-service-concept__card
              .meetia-service-concept__header
                span.meetia-service-concept__num = card[:num]
                h3.meetia-service-concept__title = card[:title]
              p.meetia-service-concept__desc = card[:desc]
              .meetia-service-concept__illust aria-hidden="true"
                .meetia-service-concept__icon-stage
