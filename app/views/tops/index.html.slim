                  span.meetia-ai-deal-flow__step-num 2
                  p = t("meetia.lp.body.flow_room_caption")
                .meetia-ai-deal-flow__panel.meetia-ai-deal-flow__panel--room
                  .meetia-flow-room aria-hidden="true"
                    header.meetia-flow-room__header
                      .meetia-flow-room__status
                        span.meetia-flow-room__status-dot
                        span = t("meetia.lp.body.flow_ai_live")
                        span.meetia-flow-room__timer 00:08:42
                      button.meetia-flow-room__exit type="button" tabindex="-1"
                        span ↗
                        span = t("meetia.lp.body.flow_exit")

                    .meetia-flow-room__body
                      .meetia-flow-room__deck
                        .meetia-flow-room__deck-label = t("meetia.lp.body.flow_deck_label")
                        .meetia-flow-room__slide
                          span.meetia-flow-room__slide-company = t("meetia.lp.body.flow_slide_company")
                          strong.meetia-flow-room__slide-title = t("meetia.lp.body.flow_slide_title")
                          h3 = t("meetia.lp.body.flow_slide_h3")
                        .meetia-flow-room__deck-foot
                          .meetia-flow-room__pager
                            button type="button" tabindex="-1" ‹
                            span 1 / 24
                            button type="button" tabindex="-1" ›
                          .meetia-flow-room__deck-actions
                            button type="button" tabindex="-1"
                              i.fa-solid.fa-magnifying-glass-plus aria-hidden="true"
                              = t("meetia.lp.body.flow_zoom")
                            button type="button" tabindex="-1"
                              i.fa-solid.fa-download aria-hidden="true"
                              = t("meetia.lp.body.flow_download")

                      aside.meetia-flow-room__agent
                        = image_tag "avatar_3.png", alt: "", class: "meetia-flow-room__avatar"
                        .meetia-flow-room__chat
                          .meetia-flow-room__chat-head
                            i.fa-solid.fa-robot aria-hidden="true"
                            span = t("meetia.lp.body.flow_assistant")
                          .meetia-flow-room__messages
                            .meetia-flow-room__message.meetia-flow-room__message--ai
                              p = t("meetia.lp.body.flow_assistant_msg")
                          .meetia-flow-room__input
                            input type="text" placeholder=t("meetia.lp.body.flow_input_ph") disabled=""
                            button type="button" tabindex="-1" aria-label=t("meetia.lp.body.aria_send")
                              i.fa-solid.fa-paper-plane aria-hidden="true"

                    .meetia-flow-room__footer
                      p.meetia-flow-room__topics-label = t("meetia.lp.body.flow_topics_label")
                      .meetia-flow-room__topics
                        span = t("meetia.lp.body.flow_topic_1")
                        span = t("meetia.lp.body.flow_topic_2")
                        span = t("meetia.lp.body.flow_topic_3")
                        span = t("meetia.lp.body.flow_topic_4")
                        span = t("meetia.lp.body.flow_topic_5")
                      .meetia-flow-room__voice
                        .meetia-flow-room__wave aria-hidden="true"
                          i
                          i
                          i
                          i
                          i
                        span = t("meetia.lp.body.flow_speaking")

              span.meetia-ai-deal-flow__arrow aria-hidden="true"
                i.fa-solid.fa-chevron-right

              .meetia-ai-deal-flow__step
                .meetia-ai-deal-flow__step-label
                  span.meetia-ai-deal-flow__step-num 3
                  p
                    = t("meetia.lp.body.flow_dash_1")
                    br
                    = t("meetia.lp.body.flow_dash_2")
                .meetia-ai-deal-flow__panel.meetia-ai-deal-flow__panel--dashboard
                  .meetia-ai-deal-flow__dash-card
                    .meetia-ai-deal-flow__dash-head
                      span = t("meetia.lp.body.flow_intent")
                      strong A
                    p.meetia-ai-deal-flow__dash-grade = t("meetia.lp.body.flow_grade")
                    .meetia-ai-deal-flow__dash-bar aria-hidden="true"
                      span
                  h4.meetia-ai-deal-flow__dash-section = t("meetia.lp.body.flow_summary")
                  ul.meetia-ai-deal-flow__dash-list
                    li
                      i.fa-solid.fa-check aria-hidden="true"
                      span = t("meetia.lp.body.flow_sum_1")
                    li
                      i.fa-solid.fa-check aria-hidden="true"
                      span = t("meetia.lp.body.flow_sum_2")
                    li
                      i.fa-solid.fa-check aria-hidden="true"
                      span = t("meetia.lp.body.flow_sum_3")
                    li
                      i.fa-solid.fa-check aria-hidden="true"
                      span = t("meetia.lp.body.flow_sum_4")
                  .meetia-ai-deal-flow__dash-follow
                    span.meetia-ai-deal-flow__dash-follow-label = t("meetia.lp.body.flow_follow_label")
                    .meetia-ai-deal-flow__dash-follow-box
                      i.fa-solid.fa-envelope aria-hidden="true"
                      p
                        strong = t("meetia.lp.body.flow_follow_mail")
                        = t("meetia.lp.body.flow_follow_sched")
                  button.meetia-ai-deal-flow__dash-btn type="button" tabindex="-1" = t("meetia.lp.body.flow_report")
            button.meetia-ai-deal-flow__scroll-btn.meetia-ai-deal-flow__scroll-btn--next type="button" aria-label=t("meetia.lp.body.aria_next") data-lp-scroll-next=".meetia-ai-deal-flow__steps"
              i.fa-solid.fa-chevron-right aria-hidden="true"

          p.meetia-ai-deal-flow__foot
            = t("meetia.lp.body.flow_footer_1")
