# === AI Interview System 環境変数テンプレート ===
# このファイルをコピーして .env を作成してください
# cp .env.example .env

# --- 必須: OpenAI API ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- オプション: Anthropic Claude (代替LLM) ---
# CLAUDE_API_KEY=sk-ant-your-claude-api-key

# --- オプション: 記事生成用 ---
# GPT_API_KEY=sk-your-gpt-api-key
# GEMINI_API_KEY=your-gemini-api-key

# --- DB (PostgreSQL) ---
# 未設定時: development/test は SQLite。
# DATABASE_URL を設定すると development も PostgreSQL になる（SQLite 設定は混ざらない）。
# 本番は RAILS_ENV=production + DATABASE_URL（または下記個別設定）。
# DATABASE_URL=postgresql://meetia:your-db-password@localhost:5432/meetia_production
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=meetia_production
# DB_USERNAME=meetia
# DB_PASSWORD=your-db-password

# --- Redis (Sidekiq) ---
# REDIS_URL=redis://localhost:6379/0

# --- Rails ---
# RAILS_ENV=production
# RAILS_MASTER_KEY=your-master-key
# RAILS_ALLOWED_HOST=meetia.pro
# RAILS_SERVE_STATIC_FILES=true
# RAILS_LOG_TO_STDOUT=true
# FORCE_SSL=true

# --- サーバー ---
# PORT=3000
# WEB_CONCURRENCY=2
# RAILS_MAX_THREADS=5
# SIDEKIQ_CONCURRENCY=10

# --- テストモード (開発環境のみ) ---
# AI_INTERVIEW_TEST_MODE=true

# --- LLM 設定 ---
# LLM_MODEL=openai                # openai / claude
# OPENAI_MODEL=gpt-4              # OpenAI モデル名
# CLAUDE_MODEL=claude-sonnet-4-20250514
# LLM_TEMPERATURE=0.2             # 評価用温度パラメータ
# LLM_MAX_TOKENS=600
# LLM_MAX_RETRIES=3
# LLM_REQUEST_TIMEOUT=30          # 秒

# --- STT (Speech-to-Text) 設定 ---
# STT_MODEL=whisper-1
# STT_MAX_FILE_SIZE_MB=25
# STT_MAX_RETRIES=2
# STT_TIMEOUT=60                  # 秒

# --- TTS (Text-to-Speech) 設定 ---
# TTS_MODEL=tts-1
# TTS_MAX_TEXT_LENGTH=4096
# TTS_MAX_RETRIES=2
# TTS_TIMEOUT=30                  # 秒
# TTS_DEFAULT_VOICE=nova
# TTS_VOICE_JA=nova
# TTS_VOICE_EN=nova

# --- メディア処理 設定 ---
# MAX_VIDEO_SIZE_MB=500
# MAX_AUDIO_SIZE_MB=25
# FFMPEG_TIMEOUT=120              # 秒
# MIN_AUDIO_DURATION=0.5          # 秒
# MAX_AUDIO_DURATION=600          # 秒

# --- 評価設定 ---
# DEFAULT_PASS_THRESHOLD=70       # デフォルト合格スコア
# EVAL_WEIGHT_RELEVANCE=0.4       # 関連性の重み
# EVAL_WEIGHT_CORRECTNESS=0.4     # 正確性の重み
# EVAL_WEIGHT_CLARITY=0.2         # 明瞭性の重み

# --- メール ---
# EMAIL_PASSWORD=your-email-password

# --- Stripe (サブスクリプション) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...    # スターター ¥29,800/月
# STRIPE_PRICE_STANDARD=price_...   # スタンダード ¥59,800/月
# STRIPE_PRICE_BUSINESS=price_...   # Business ¥98,000/月
# STRIPE_PRICE_ENTERPRISE=price_... # エンタープライズ ¥198,000/月

# --- Meta Pixel (広告計測) ---
# META_PIXEL_ID=1745060629862730
