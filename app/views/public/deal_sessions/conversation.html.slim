.admin-container
  h1.admin-title AI商談
  p.admin-subtitle = @deal.title

  .admin-card
    .conversation-layout
      .conversation-main
        .conversation-wrapper
          .conversation-header
            .conversation-status
              span.status-badge.status-badge--progress 進行中
            .conversation-info
              = @deal.client.email

          .conversation-messages#conversation-messages
            - @conversation_messages.each do |msg|
              .message.message--assistant
                .message-header
                  span.message-role AIアシスタント
                  span.message-time = Time.current.strftime('%H:%M')
                .message-content = simple_format(msg[:content])
                .message-actions
                  button.btn-audio type="button" data-text=msg[:content] title="音声再生"
                    | 🔊

          .conversation-input-area
            .topic-selection
              h3.topic-title 知りたいトピックを選択
              .topic-buttons
                = button_tag 'サービス概要', class: 'btn-topic', data: { topic: 'overview' }
                = button_tag '料金プラン', class: 'btn-topic', data: { topic: 'pricing' }
                = button_tag 'トライアル', class: 'btn-topic', data: { topic: 'trial' }
                = button_tag '契約フロー', class: 'btn-topic', data: { topic: 'contract' }

        .conversation-footer
          = button_tag '商談を終了', class: 'btn-secondary-custom', id: 'end-conversation-btn'

      .avatar-area
        .avatar-image
          .avatar-frame
            = image_tag 'avatar_1.png', alt: 'アバター1', class: 'avatar-img avatar-img-1'
            = image_tag 'avatar_2.png', alt: 'アバター2', class: 'avatar-img avatar-img-2'

      .conversation-sidebar
        .sidebar-header
          h3.sidebar-title 資料
        .sidebar-content
          - if @deal.deal_documents.any?
            .document-list
              - @deal.deal_documents.each_with_index do |doc, index|
                .document-item id="doc-#{doc.id}" data-document-id=doc.id
                  .document-header
                    span.document-name = File.basename(doc.file.filename.to_s)
                    button.btn-toggle-doc type="button" data-doc-id=doc.id
                      | ▼
                  .document-preview id="preview-#{doc.id}" style="display: none;"
                    - if doc.file.content_type&.include?('image')
                      = image_tag url_for(doc.file), class: 'document-image'
                    - elsif doc.file.content_type&.include?('pdf')
                      iframe src=url_for(doc.file) class="document-pdf"
                    - else
                      .document-file
                        = link_to '資料をダウンロード', url_for(doc.file), target: '_blank', class: 'btn-download'
          - else
            .no-documents
              p 資料がありません

# 評価モーダル
.modal id='evaluation-modal' style='display: none;'
  .modal-content
    .modal-header
      h2 商談評価
      = button_tag '×', class: 'modal-close', id: 'close-modal'
    .modal-body
      .form-group
        label.form-label 満足度（星5つ中）
        .star-rating
          - 5.times do |i|
            = radio_button_tag 'rating', 5 - i, false, id: "star-#{5 - i}", class: 'star-rating-input'
            = label_tag "star-#{5 - i}", '★', class: 'star-rating-label'
      .form-group
        = label_tag 'feedback', 'ご意見・ご要望', class: 'form-label'
        = text_area_tag 'feedback', '', class: 'form-control', rows: 4, placeholder: '自由にご意見をお聞かせください'
    .modal-footer
      = button_tag '送信', class: 'btn-primary-custom', id: 'submit-evaluation'

javascript:
  document.addEventListener('DOMContentLoaded', function() {
    // トピック選択
    const topicButtons = document.querySelectorAll('.btn-topic');
    topicButtons.forEach(btn => {
      btn.addEventListener('click', function() {
        const topic = this.dataset.topic;
        const topicText = this.textContent;
        addMessage(topicText, 'user');

        // ローディング表示
        const loadingDiv = document.createElement('div');
        loadingDiv.className = 'message message--assistant loading';
        loadingDiv.innerHTML = '<div class="message-content">入力中...</div>';
        document.querySelector('.conversation-messages').appendChild(loadingDiv);
        document.querySelector('.conversation-messages').scrollTop = document.querySelector('.conversation-messages').scrollHeight;

        // AI応答をAPIから取得
        fetchAIResponse(topic).then(response => {
          loadingDiv.remove();
          addMessage(response, 'assistant');
        }).catch(error => {
          loadingDiv.remove();
          addMessage(getAIResponse(topic), 'assistant');
        });
      });
    });

    // 資料の開閉
    document.querySelectorAll('.btn-toggle-doc').forEach(btn => {
      btn.addEventListener('click', function() {
        const docId = this.dataset.docId;
        const preview = document.getElementById('preview-' + docId);
        const isHidden = preview.style.display === 'none';

        // すべてのプレビューを閉じる
        document.querySelectorAll('.document-preview').forEach(p => {
          p.style.display = 'none';
        });

        // クリックされた資料のみ開閉
        preview.style.display = isHidden ? 'block' : 'none';
        this.textContent = isHidden ? '▲' : '▼';
      });
    });

    // 音声ボタン
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('btn-audio')) {
        const text = e.target.dataset.text;
        speakText(text);
      }
    });

    // 商談終了ボタン
    document.getElementById('end-conversation-btn').addEventListener('click', function() {
      document.getElementById('evaluation-modal').style.display = 'block';
    });

    // モーダル閉じる
    document.getElementById('close-modal').addEventListener('click', function() {
      document.getElementById('evaluation-modal').style.display = 'none';
    });

    // モーダル外クリックで閉じる
    document.getElementById('evaluation-modal').addEventListener('click', function(e) {
      if (e.target === this) {
        this.style.display = 'none';
      }
    });

    // 評価送信
    document.getElementById('submit-evaluation').addEventListener('click', function() {
      document.getElementById('evaluation-modal').style.display = 'none';
      alert('評価を送信しました。ありがとうございました！');
    });
  });

  function addMessage(content, role) {
    const messagesContainer = document.querySelector('.conversation-messages');
    const messageDiv = document.createElement('div');
    messageDiv.className = `message message--${role}`;
    
    const time = new Date().toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' });
    const roleText = role === 'assistant' ? 'AIアシスタント' : 'あなた';
    
    messageDiv.innerHTML = `
      <div class="message-header">
        <span class="message-role">${roleText}</span>
        <span class="message-time">${time}</span>
      </div>
      <div class="message-content">${content.replace(/\n/g, '<br>')}</div>
      ${role === 'assistant' ? '<div class="message-actions"><button type="button" class="btn-audio" data-text="' + content.replace(/"/g, '&quot;').replace(/\n/g, ' ') + '" title="音声再生">🔊</button></div>' : ''}
    `;
    
    messagesContainer.appendChild(messageDiv);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  async function fetchAIResponse(topic) {
    try {
      const response = await fetch('/api/ai_response', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
        },
        body: JSON.stringify({
          topic: topic,
          deal_id: #{@deal.id}
        })
      });

      if (response.ok) {
        const data = await response.json();
        return data.response;
      } else {
        throw new Error('API error');
      }
    } catch (error) {
      console.error('AI response error:', error);
      return getAIResponse(topic);
    }
  }

  function getAIResponse(topic) {
    const responses = {
      overview: 'サービス概要について説明します。私たちのAI商談システムは、音声認識と要約生成を組み合わせた革新的なソリューションです。',
      pricing: '料金プランについて説明します。基本プランは月額10,000円から始まり、企業規模に応じた柔軟なプランをご用意しています。',
      trial: 'トライアルについて説明します。14日間の無料トライアルをご用意しており、すべての機能をお試しいただけます。',
      contract: '契約フローについて説明します。オンラインで完結するシンプルな手続きとなっており、最短即日で利用開始可能です。'
    };
    return responses[topic] || '申し訳ありません、そのトピックについての情報を取得できませんでした。';
  }

  function speakText(text) {
    if ('speechSynthesis' in window) {
      // 既存の音声を停止
      window.speechSynthesis.cancel();

      const utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = 'ja-JP';
      utterance.rate = 1.0;
      utterance.pitch = 1.0;
      utterance.volume = 1.0;

      // 音声がロードされた後に設定
      window.speechSynthesis.getVoices();
      const voices = window.speechSynthesis.getVoices();
      const japaneseVoice = voices.find(voice => voice.lang === 'ja-JP' || voice.lang === 'ja_JP');
      if (japaneseVoice) {
        utterance.voice = japaneseVoice;
      }

      window.speechSynthesis.speak(utterance);
    } else {
      alert('お使いのブラウザは音声合成をサポートしていません。');
    }
  }

  // 音声がロードされた後に再度設定
  window.speechSynthesis.onvoiceschanged = function() {
    window.speechSynthesis.getVoices();
  };
