                    i.fa-solid class=card[:icon]
                  span.meetia-service-concept__icon-orbit
                    i.fa-solid class=card[:orbit]
        button.meetia-service-concept__scroll-btn.meetia-service-concept__scroll-btn--next type="button" aria-label=t("meetia.lp.body.aria_next") data-lp-scroll-next=".meetia-service-concept__grid"
          i.fa-solid.fa-chevron-right aria-hidden="true"

  section#features.meetia-section.meetia-section--strip.meetia-features-page
    .meetia-section__inner.meetia-section__inner--wide
      .meetia-features-page__head
        span.meetia-section__eyebrow FEATURES
        h2.meetia-features-page__title = t("meetia.lp.features_title")
        p.meetia-features-page__lead = t("meetia.lp.features_lead")
      .meetia-features-showcase
        .meetia-features-showcase__grid
          - feature_rows.each do |(num, icon, title, body, _)|
            - if num == "03"
              article.meetia-feature-focus data-feature=num
                .meetia-feature-focus__head
                  .meetia-feature-focus__head-icon
                    i.fa-solid class=icon aria-hidden="true"
                  .meetia-feature-focus__head-main
                    p.meetia-feature-focus__num = num
                    h2.meetia-feature-focus__title = title
                    p.meetia-feature-focus__body = body
                .meetia-feature-focus__screen
                  = image_tag "top_hero_portal.png", alt: t("meetia.lp.body.feature_focus_alt"), class: "meetia-feature-focus__image"
            - else
              article.meetia-feature-card data-feature=num
                .meetia-feature-card__icon
                  i.fa-solid class=icon aria-hidden="true"
                .meetia-feature-card__content
                  p.meetia-feature-card__num = num
                  h3.meetia-feature-card__title = title
                  p.meetia-feature-card__body = body
                span.meetia-feature-card__arrow aria-hidden="true"
                  i.fa-solid.fa-chevron-right

        .meetia-features-showcase__cta
          p.meetia-features-showcase__cta-copy = t("meetia.lp.body.features_cta_copy")
          .meetia-features-showcase__cta-actions
            = link_to lp_sign_up_path, class: "meetia-btn meetia-btn--primary meetia-btn--lg meetia-btn--pill" do
              = t("meetia.lp.cta_start_meetia")
              i.fa-solid.fa-chevron-right aria-hidden="true"
            = link_to plans_path, class: "meetia-btn meetia-btn--outline meetia-btn--lg meetia-btn--pill" do
              i.fa-solid.fa-download aria-hidden="true"
              = t("meetia.lp.body.features_dl")

  section#pricing.meetia-section.meetia-pricing-section
    .meetia-section__inner.meetia-section__inner--wide
      .meetia-section__head
        span.meetia-section__eyebrow PRICING
        h2.meetia-section__title = t("meetia.lp.body.pricing_title")
        p.meetia-section__lead = t("meetia.lp.body.pricing_lead")
      / Subscription::PLAN_CATALOG から LP 料金セクションを描画（/plans と同一ソース）
      - visible_plans = Subscription.lp_display_plans

      .meetia-pricing__slider data-pricing-slider=""
        p.meetia-pricing__scroll-hint = t("meetia.lp.body.pricing_hint")
        .meetia-pricing__slider-body
          button.meetia-pricing__arrow.meetia-pricing__arrow--prev type="button" aria-label=t("meetia.lp.body.aria_prev_plan") data-pricing-prev=""
            svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
              polyline points="15 18 9 12 15 6"
          .meetia-pricing__viewport
            .meetia-pricing__track
              - visible_plans.each do |plan_key, config|
                - is_trial = plan_key == :trial
                - card_classes = []
                - card_classes << 'meetia-pricing__card--popular' if config[:popular]
                - card_classes << 'meetia-pricing__card--featured' if config[:featured]
                - card_classes << 'meetia-pricing__card--trial' if is_trial
                .meetia-pricing__card class=card_classes.join(' ')
                  - if config[:popular]
                    .meetia-pricing__badge.meetia-pricing__badge--popular POPULAR
                  - if config[:featured]
                    .meetia-pricing__badge RECOMMENDED
                  - if is_trial
                    .meetia-pricing__badge.meetia-pricing__badge--trial FREE TRIAL
                  .meetia-pricing__card-head
                    h3.meetia-pricing__plan = config[:name]
                    .meetia-pricing__price
                      span.meetia-pricing__currency ¥
                      span.meetia-pricing__amount = number_with_delimiter(config[:price])
                      - if is_trial
                        span.meetia-pricing__period = " / #{Subscription::TRIAL_DAYS}#{t('meetia.lp.body.pricing_days')}"
                      - else
                        span.meetia-pricing__period = " / #{t('meetia.lp.body.pricing_month')}"
                    p.meetia-pricing__desc = config[:description]
                  ul.meetia-pricing__features
                    - Subscription::LP_COMPARISON_FEATURES.each do |feature|
                      li.meetia-pricing__feature
                        span.meetia-pricing__feature-label = feature[:label]
                        span.meetia-pricing__feature-value = Subscription.format_feature_value(plan_key, feature[:key])
                  .meetia-pricing__card-foot
                    - cta_label = config[:lp_cta].presence || t("meetia.lp.body.pricing_cta_default")
                    - btn_class = is_trial ? "meetia-btn meetia-btn--secondary meetia-pricing__card-btn" : "meetia-btn meetia-btn--primary meetia-pricing__card-btn"
                    = link_to cta_label, new_client_registration_path, class: btn_class
          button.meetia-pricing__arrow.meetia-pricing__arrow--next type="button" aria-label=t("meetia.lp.body.aria_next_plan") data-pricing-next=""
            svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
              polyline points="9 18 15 12 9 6"

      .meetia-pricing__cta
        = link_to t("meetia.lp.body.pricing_trial_cta"), new_client_registration_path, class: "meetia-btn meetia-btn--primary meetia-btn--lg"

  section#compare.meetia-section
    .meetia-section__inner
      .meetia-section__head
        span.meetia-section__eyebrow WHY MEETIA?
        h2.meetia-section__title
          = t("meetia.lp.body.compare_title_1")
          span.meetia-text-gradient = t("meetia.lp.body.compare_title_2")
        p.meetia-section__lead = t("meetia.lp.body.compare_lead")

      .meetia-compare-scroll-wrap
        button.meetia-compare-scroll-btn.meetia-compare-scroll-btn--prev type="button" aria-label=t("meetia.lp.body.aria_prev") data-lp-scroll-prev=".meetia-compare-scroll"
          i.fa-solid.fa-chevron-left aria-hidden="true"
        .meetia-compare-scroll
          .meetia-compare-table
            .meetia-compare-table__glow aria-hidden="true"
            .meetia-compare-table__head
              span.meetia-compare-table__label = t("meetia.lp.body.compare_label")
              span.meetia-compare-table__col.meetia-compare-table__col--meetia
                span.meetia-compare-table__brand
                  i.fa-solid.fa-sparkles aria-hidden="true"
                  | Meetia
              span.meetia-compare-table__col = t("meetia.lp.body.compare_legacy")
            - compare_rows.each do |row|
              .meetia-compare-table__row
                .meetia-compare-table__topic
                  span.meetia-compare-table__icon aria-hidden="true"
                    i.fa-solid class=row[:icon]
                  span = row[:label]
                .meetia-compare-table__cell.meetia-compare-table__cell--meetia
                  span.meetia-compare-table__mark.meetia-compare-table__mark--ok aria-hidden="true"
                    i.fa-solid.fa-check
                  span = row[:meetia]
                .meetia-compare-table__cell
                  span.meetia-compare-table__mark.meetia-compare-table__mark--ng aria-hidden="true"
                    i.fa-solid.fa-xmark
                  span = row[:legacy]
        button.meetia-compare-scroll-btn.meetia-compare-scroll-btn--next type="button" aria-label=t("meetia.lp.body.aria_next") data-lp-scroll-next=".meetia-compare-scroll"
          i.fa-solid.fa-chevron-right aria-hidden="true"

      .meetia-compare-cta
        .meetia-compare-cta__text-block
          span.meetia-compare-cta__badge = t("meetia.lp.body.compare_badge")
          p.meetia-compare-cta__lead = t("meetia.lp.body.compare_cta_lead")
        .meetia-compare-cta__actions
          = link_to lp_trial_experience_path, lp_trial_experience_link_options.merge(class: "meetia-btn meetia-btn--primary meetia-btn--lg") do
            = t("meetia.lp.body.compare_cta_demo")
            i.fa-solid.fa-chevron-right aria-hidden="true"
          = link_to "#features", class: "meetia-btn meetia-btn--outline meetia-btn--lg" do
            = t("meetia.lp.body.compare_cta_features")
            i.fa-solid.fa-arrow-right aria-hidden="true"

  section#reviews.meetia-section.meetia-section--strip
    .meetia-section__inner
      .meetia-section__head
        span.meetia-section__eyebrow REVIEWS
        h2.meetia-section__title = t("meetia.lp.body.reviews_title")
        p.meetia-section__lead = t("meetia.lp.body.reviews_lead")
      .meetia-reviews-summary
        .meetia-reviews-summary__stat
          span.meetia-reviews-summary__value 4.8
          span.meetia-reviews-summary__label
            | / 5.0
        .meetia-reviews-summary__stat
          span.meetia-reviews-summary__value 1,200+
          span.meetia-reviews-summary__label = t("meetia.lp.body.reviews_companies")
        .meetia-reviews-summary__stat
          span.meetia-reviews-summary__value 98%
          span.meetia-reviews-summary__label = t("meetia.lp.body.reviews_retention")
      .meetia-reviews-slider data-reviews-slider=""
        button.meetia-reviews-slider__btn.meetia-reviews-slider__btn--prev type="button" aria-label=t("meetia.lp.body.aria_prev_review") data-reviews-prev=""
          i.fa-solid.fa-chevron-left aria-hidden="true"
        .meetia-reviews-slider__viewport
          .meetia-reviews-slider__track
            - review_cards.each do |card|
              .meetia-cases__card
                .meetia-cases__meta = card[:meta]
                .meetia-cases__stars ★★★★★
                h3 = card[:title]
                p = card[:quote]
                span.meetia-cases__metric = card[:metric]
        button.meetia-reviews-slider__btn.meetia-reviews-slider__btn--next type="button" aria-label=t("meetia.lp.body.aria_next_review") data-reviews-next=""
          i.fa-solid.fa-chevron-right aria-hidden="true"

  section#faq.meetia-section
    .meetia-section__inner
      .meetia-section__head
        span.meetia-section__eyebrow FAQ
        h2.meetia-section__title = t("meetia.lp.body.faq_title")
        p.meetia-section__lead = t("meetia.lp.body.faq_lead")
      .meetia-faq-search
        input.meetia-faq-search__input type="search" placeholder=t("meetia.lp.body.faq_search_ph") data-faq-search=""
        i.fa-solid.fa-magnifying-glass aria-hidden="true"
      .meetia-faq-layout data-faq-root=""
        nav.meetia-faq-categories aria-label=t("meetia.lp.body.aria_faq_cat")
          h3 = t("meetia.lp.body.faq_categories")
          - faq_categories.each_with_index do |(key, label, icon), idx|
            button.meetia-faq-categories__btn type="button" class=("is-active" if idx.zero?) data-faq-category=key
              i.fa-solid class=icon aria-hidden="true"
              span = label
              i.fa-solid.fa-chevron-right aria-hidden="true"
        .meetia-faq-panel
          - faq_items.each_with_index do |item, idx|
            details.meetia-faq-panel__item class=("is-open-default" if idx.zero?) data-faq-item=item[:category] open=(idx.zero? || nil)
              summary.meetia-faq-panel__q = item[:q]
              p.meetia-faq-panel__a = item[:a]
      .meetia-faq-contact
        p = t("meetia.lp.body.faq_unresolved")
        = link_to "#company", class: "meetia-btn meetia-btn--primary meetia-btn--lg" do
          i.fa-solid.fa-envelope aria-hidden="true"
          span = t("meetia.lp.body.faq_contact")




  section.meetia-deal-flow
    .meetia-deal-flow__inner
      /-- セクションタイトル部 --/
      .meetia-deal-flow__head
        span.meetia-section__eyebrow HOW IT WORKS
        h2.meetia-deal-flow__title = t("meetia.lp.body.dealflow_title")
        p.meetia-deal-flow__lead = t("meetia.lp.body.dealflow_lead")

      /-- 3ステップフローコンテナ --/
      .meetia-deal-flow__scroll-wrap
        button.meetia-deal-flow__scroll-btn.meetia-deal-flow__scroll-btn--prev type="button" aria-label=t("meetia.lp.body.aria_prev") data-lp-scroll-prev=".meetia-deal-flow__container"
          i.fa-solid.fa-chevron-left aria-hidden="true"
        .meetia-deal-flow__container
        
          /-- STEP 1 --/
          .meetia-deal-flow__step-card
            .meetia-deal-flow__step-num STEP 01
            .meetia-deal-flow__icon-wrap
              i.fa-solid.fa-link
            h3.meetia-deal-flow__step-title = t("meetia.lp.body.dealflow_s1_title")
            p.meetia-deal-flow__step-desc = t("meetia.lp.body.dealflow_s1_desc")

          /-- 矢印（デスクトップでは横、スマホでは非表示） --/
          .meetia-deal-flow__arrow
            i.fa-solid.fa-chevron-right

          /-- STEP 2 --/
          .meetia-deal-flow__step-card
            .meetia-deal-flow__step-num STEP 02
            .meetia-deal-flow__icon-wrap
              i.fa-solid.fa-microphone-lines
            h3.meetia-deal-flow__step-title = t("meetia.lp.body.dealflow_s2_title")
            p.meetia-deal-flow__step-desc = t("meetia.lp.body.dealflow_s2_desc")

          /-- 矢印 --/
          .meetia-deal-flow__arrow
            i.fa-solid.fa-chevron-right

          /-- STEP 3 --/
          .meetia-deal-flow__step-card
            .meetia-deal-flow__step-num STEP 03
            .meetia-deal-flow__icon-wrap
              i.fa-solid.fa-chart-pie
            h3.meetia-deal-flow__step-title = t("meetia.lp.body.dealflow_s3_title")
            p.meetia-deal-flow__step-desc = t("meetia.lp.body.dealflow_s3_desc")
        button.meetia-deal-flow__scroll-btn.meetia-deal-flow__scroll-btn--next type="button" aria-label=t("meetia.lp.body.aria_next") data-lp-scroll-next=".meetia-deal-flow__container"
          i.fa-solid.fa-chevron-right aria-hidden="true"




  section#company.meetia-section.meetia-section--strip
    .meetia-section__inner.meetia-section__inner--wide

      .meetia-company-profile
        .meetia-company-profile__head
          span.meetia-section__eyebrow ABOUT US
          h2.meetia-company-profile__title = t("meetia.lp.body.company_title")
          p.meetia-company-profile__lead = t("meetia.lp.body.company_lead")

        .meetia-company-profile__grid
          .meetia-company-profile__left
            h3.meetia-company-profile__catch
              = t("meetia.lp.body.company_mission_1")
              br
              = t("meetia.lp.body.company_mission_2")
              span.meetia-text-gradient = t("meetia.lp.body.company_mission_3")
            p.meetia-company-profile__mission-text = t("meetia.lp.body.company_mission_text")
            .meetia-company-profile__stats
              - company_stats.each do |stat|
                .meetia-company-profile__stat
                  .meetia-company-profile__stat-icon
                    i.fa-solid class=stat[:icon] aria-hidden="true"
                  span.meetia-company-profile__stat-label = stat[:label]
                  .meetia-company-profile__stat-num
                    span = stat[:num]
                    small = stat[:unit]

          .meetia-company-profile__right
            .meetia-company-profile__facts
              - company_profile_rows.each do |label, value|
                .meetia-company-profile__row
                  .meetia-company-profile__th = label
                  .meetia-company-profile__td = value

  section.meetia-cta-band
    .meetia-cta-band__inner
      .meetia-cta-band__header
        span.meetia-cta-band__badge
          i.fa-solid.fa-bolt aria-hidden="true"
          | TRIAL
        h2.meetia-cta-band__title
          = "#{Subscription::TRIAL_DAYS}#{t('meetia.lp.body.cta_band_title')}"
        p.meetia-cta-band__lead = t("meetia.lp.body.cta_band_lead")

      .meetia-cta-band__features
        - trial_features.each do |feature|
          .meetia-cta-band__feature
            .meetia-cta-band__feature-icon
              i.fa-solid class=feature[:icon] aria-hidden="true"
            h3.meetia-cta-band__feature-label = feature[:label]
            p.meetia-cta-band__feature-desc = feature[:desc]

      .meetia-cta-band__actions
        = link_to lp_sign_up_path, class: "meetia-btn meetia-btn--primary meetia-btn--lg meetia-cta-band__btn" do
          i.fa-solid.fa-rocket aria-hidden="true"
          span = t("meetia.lp.body.cta_band_btn")

  section.meetia-columns-seo#columns-seo
    .meetia-columns-seo__inner
      span.meetia-section__eyebrow Resources
      h2.meetia-columns-seo__title = t("meetia.lp.body.columns_title")
      p.meetia-columns-seo__lead = t("meetia.lp.body.columns_lead")
      ul.meetia-columns-seo__list
        - featured_columns_for_lp.each do |item|
          li = link_to item[:title], item[:path]
      p.meetia-columns-seo__more
        = link_to t("meetia.lp.body.columns_all"), "/columns", class: "meetia-btn meetia-btn--outline meetia-btn--sm"

